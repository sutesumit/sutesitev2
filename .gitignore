# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# blipincli
/blipincli/node_modules
/blipincli/dist
/blipincli/*.lock

# jotbot
/jotbot/node_modules
/jotbot/dist

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# debug logs
.next-*.log

# local tool artifacts
.kilo/
.kilocode/
.opencode/
.gemini/skills/
