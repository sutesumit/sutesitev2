{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "..",
    "declaration": false,
    "resolveJsonModule": true
  },
  "include": ["src/index.ts", "src/lib/**/*.ts", "../shared/api-contracts.ts"],
  "exclude": ["node_modules", "dist"]
}
